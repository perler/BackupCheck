# healthchecks.io keys (required)
HC_PING_KEY=your-ping-key-here
HC_API_KEY=your-api-key-here

# Repository access credentials (required)
REPO_USERNAME=domain\username
REPO_PASSWORD=your-password-here

# Atera RMM (used by pause-offline-checks.py on coordinator)
ATERA_API_KEY=your-atera-api-key-here

# Coordinator API (v2.1+, optional - enables centralized backup monitoring)
# COORDINATOR_URL=https://backupcheck.example.com/api/report
# COORDINATOR_API_KEY=your-coordinator-api-key-here
